# ============================================================
# PassI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# Set these in .env.local for local dev and in Vercel → Environment Variables for production.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe publishable key — safe for frontend
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# Your deployed app URL (no trailing slash)
# Local: http://localhost:5173
# Production: https://yourapp.vercel.app
VITE_APP_URL=http://localhost:5173

# ── Supabase Edge Function Secrets ───────────────────────────
# Set these in Supabase Dashboard → Project Settings → Edge Functions → Secrets.
# These are server-side only — never expose them to the frontend.

# Stripe secret key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=sk_test_your-secret-key-here

# Webhook signing secret from Stripe Dashboard → Webhooks
# Used for direct account webhooks (local dev / non-Connect)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Webhook signing secret for Stripe Connect platform webhooks (production)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your-connect-webhook-secret-here

# Must match VITE_APP_URL — used for Stripe success/cancel redirect URLs
APP_URL=http://localhost:5173
